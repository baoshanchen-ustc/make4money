# Analytics Configuration
# 分析工具配置

# Google Analytics 4 Measurement ID
# 获取方式：https://analytics.google.com/
# 格式：G-XXXXXXXXXX
VITE_GOOGLE_ANALYTICS_ID=

# Baidu Analytics Site ID
# 百度统计站点 ID
# 获取方式：https://tongji.baidu.com/
# 格式：一串十六进制字符
VITE_BAIDU_ANALYTICS_ID=

# Site Configuration
VITE_SITE_URL=https://ai-in.one
VITE_SITE_NAME=AI in One
